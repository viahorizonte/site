<!DOCTYPE html>
<html lang="en" class="no-js">
{% include head %}
{% if site.banner.text %}
  <body class="banner-displayed">
{% else %}
  <body>
{% endif %}
  {% include menu %}
  <div class="container">
    <div class="row">
      <div class="col-md-8">
        <main class="blog">
          <article>
            {{ content }}
          </article>
        </main>
      </div>
      <div class="col-md-4 hidden-xs hidden-sm">
        {%include ad %}
        <h2>Informes Recentes</h2>
        <ul class="posts">
          {% for post in collections.informes limit: 25 %}
            {% if post.url != page.url %}
              <li>
                <a href="{{ post.url | replace: '.html', '' }}">{{ post.data.title }}</a><br>
                <span class="date">{{ post.date | dateFormat: "d LLLL yyyy" }}</span>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
  {% include footer %}
</body>
</html>
